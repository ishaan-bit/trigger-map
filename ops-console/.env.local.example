# Ops Console — Local Development Environment
# Copy this file to .env.local and fill in the values.
#
# Generate a password hash:
#   node -e "import('bcryptjs').then(b => b.default.hash('your-password', 12).then(console.log))"
#
# Generate a JWT secret:
#   node -e "import('crypto').then(c => console.log(c.randomBytes(32).toString('hex')))"
#
# If OPS_ADMIN_PASSWORD_HASH is left empty in dev mode, a fallback
# password "admin123" will be used automatically (never in production).

OPS_ADMIN_PASSWORD_HASH=
OPS_JWT_SECRET=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

BACKEND_URL=
BACKEND_INTERNAL_KEY=

LOCAL_WORKER_URL=http://127.0.0.1:8787
LOCAL_WORKER_KEY=

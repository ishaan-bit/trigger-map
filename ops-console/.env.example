# Ops Console Admin Auth
# Generate hash: node -e "import('bcryptjs').then(b => b.default.hash('your-password', 12).then(console.log))"
OPS_ADMIN_PASSWORD_HASH=
OPS_JWT_SECRET=

# Upstash Redis (same instance as main backend)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Main backend URL (for control actions)
BACKEND_URL=https://your-backend.vercel.app
BACKEND_INTERNAL_KEY=

# Local worker (for LLM jobs — runs on developer machine)
LOCAL_WORKER_URL=http://localhost:8787
LOCAL_WORKER_KEY=

# Optional: Sentry DSN for ops-console errors
SENTRY_DSN=

{
  "name": "trigger-map-mobile",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --clear",
    "android": "expo run:android",
    "lint": "expo lint",
    "build:aab": "eas build -p android --profile production",
    "ios": "expo run:ios",
    "postinstall": "node scripts/postinstall.js"

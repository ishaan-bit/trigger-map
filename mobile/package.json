  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~18.3.12",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~8.0.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "patch-package": "^8.0.1"
  },
  "version": "1.0.0"
}

{
  "expo": {
    "name": "TriggerMap",
    "slug": "triggermap",
    "scheme": "triggermap",
    "version": "1.1.0",
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#060a12"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-google-signin/google-signin",
      [
        "expo-notifications",
        {
          "color": "#7bc9d8"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "cover",
          "backgroundColor": "#060a12",
          "android": {
            "image": "./assets/splash.png",
            "resizeMode": "cover",
            "backgroundColor": "#060a12"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "useLegacyPackaging": false
          }
        }
      ],
      "./plugins/withReactNativeIapPlayStore",
      "expo-asset",
      "expo-font"
    ],
    "android": {
      "package": "com.triggermap.app",
      "versionCode": 73,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "POST_NOTIFICATIONS"
      ],
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-padded.png",
        "backgroundColor": "#060a12"
      }
    },
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "01260807-2248-498b-8b5d-06a347fa911b"
      }
    },
    "owner": "qdenxp"
  }
}
